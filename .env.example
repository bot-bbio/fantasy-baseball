# Copy this file to ".env" and fill in your league details.
# Cookies are NOT set here -- they are captured automatically when you run
# `python setup_login.py` and stored in .auth/ (git-ignored).

# Your league's numeric ID. Find it in the league URL:
#   https://fantasy.espn.com/baseball/league?leagueId=123456  ->  123456
ESPN_LEAGUE_ID=

# The season year.
ESPN_YEAR=2026

# Your team's numeric ID within the league. Find it in your team URL:
#   https://fantasy.espn.com/baseball/team?leagueId=123456&teamId=7  ->  7
ESPN_TEAM_ID=

# IANA timezone used to decide "today" for the daily schedule.
TIMEZONE=America/Toronto

# --- Email notifications (optional) ---
# The daily job emails a summary (proposed lineup + add/drops). Send FROM your dedicated
# agent Gmail using a Gmail APP PASSWORD (not the normal password):
#   1. Enable 2-Step Verification on that Gmail account.
#   2. https://myaccount.google.com/apppasswords -> create one -> paste the 16 chars below.
# Leave these blank to disable email.
EMAIL_SENDER=
EMAIL_APP_PASSWORD=
EMAIL_RECIPIENT=

# --- Confirmation replies (optional) ---
# Nothing is applied to ESPN until you reply to the daily email (apply all / apply 1,3 / no).
# The poller (apply_job.py) reads the agent Gmail over IMAP using the SAME app password,
# so enable IMAP on that account (Gmail: Settings -> Forwarding and POP/IMAP -> Enable IMAP).
# CONFIRM_FROM is the only address whose replies are trusted; blank = EMAIL_RECIPIENT.
IMAP_HOST=imap.gmail.com
CONFIRM_FROM=

# Safety net (optional): if you don't reply within this many minutes, the poller auto-applies
# ONLY the lineup (never add/drops) so you don't miss the lock. Blank = confirm everything.
LINEUP_FALLBACK_MINUTES=
